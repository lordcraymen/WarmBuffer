{
  "name": "@lordcraymen/warmbuffer",
  "version": "0.1.0",
  "description": "A pre-warmed object buffer for fast, low-latency object retrieval",
  "author": "lordcraymen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lordcraymen/WarmBuffer.git"
  },
  "homepage": "https://github.com/lordcraymen/WarmBuffer#readme",
  "bugs": {
    "url": "https://github.com/lordcraymen/WarmBuffer/issues"
  },
  "main": "./dist/warmbuffer.umd.js",
  "module": "./dist/warmbuffer.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/warmbuffer.mjs",
      "require": "./dist/warmbuffer.umd.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^3.0.0"
  },
  "lint-staged": {
    "*.ts": [
      "vitest related --run"
    ]
  }
}
